# Desarrollo local
NODE_ENV=development
PORT=3000
JWT_SECRET=replace-with-a-long-random-secret
MANUS_RUNTIME=false
MANUS_DEBUG_COLLECTOR=false

# Base de datos
# Opcional para abrir el dashboard en modo local con datos vacios.
DATABASE_URL=mysql://user:password@localhost:3306/cap_dashboard

# OAuth / autenticacion
# Necesario solo si quieres login real. Si se deja sin configurar en desarrollo,
# el proyecto usa el usuario local de fallback para abrir el dashboard.
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://oauth.example.com
OAUTH_SERVER_URL=https://oauth-api.example.com
OWNER_OPEN_ID=owner-open-id

# Integraciones Forge / mapas / funciones asistidas
BUILT_IN_FORGE_API_URL=https://forge.example.com
BUILT_IN_FORGE_API_KEY=your-server-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://forge.example.com
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# Integraciones opcionales
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-id